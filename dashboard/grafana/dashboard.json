{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "description": "campus_iot database",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "9.0.0" },
    { "type": "datasource", "id": "postgres",   "name": "PostgreSQL",  "version": "1.0.0" },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel",      "id": "table",      "name": "Table",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Ashesi Campus IoT — Light monitoring across 4 nodes",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Live Light Readings",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "displayName": "${__field.labels.metric}"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT ts AS \"time\", value, CASE node_id WHEN 1 THEN 'A - Mech Workshop' WHEN 2 THEN 'B - PNRB' WHEN 3 THEN 'C - Eng Block' WHEN 4 THEN 'D - Fab Lab' END AS metric FROM sensor_readings WHERE measurement = 'light' AND $__timeFilter(ts) ORDER BY ts ASC",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Light Level (ADC 0–4095) — All Nodes",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 11,
      "title": "Latest Values",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-blue", "value": null },
              { "color": "blue",      "value": 500 },
              { "color": "yellow",    "value": 2000 },
              { "color": "orange",    "value": 3500 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 11 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT MAX(CASE WHEN node_id = 1 THEN value END) AS \"A - Mech Workshop\", MAX(CASE WHEN node_id = 2 THEN value END) AS \"B - PNRB\", MAX(CASE WHEN node_id = 3 THEN value END) AS \"C - Eng Block\", MAX(CASE WHEN node_id = 4 THEN value END) AS \"D - Fab Lab\" FROM sensor_readings WHERE measurement = 'light' AND id IN (SELECT MAX(id) FROM sensor_readings WHERE measurement = 'light' GROUP BY node_id)",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Current Light Level per Node",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "id": 5,
      "options": { "sortBy": [{ "displayName": "Node ID", "desc": false }] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "rawSql": "SELECT s.node_id AS \"Node ID\", CASE s.node_id WHEN 1 THEN 'A - Mech Workshop' WHEN 2 THEN 'B - PNRB' WHEN 3 THEN 'C - Eng Block' WHEN 4 THEN 'D - Fab Lab' END AS \"Location\", s.status AS \"Status\", s.updated AS \"Last Seen\" FROM node_status s ORDER BY s.node_id",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Node Status",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["iot", "campus", "ashesi"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Africa/Accra",
  "title": "Campus IoT Dashboard",
  "uid": "campus-iot-v1",
  "version": 1
}
